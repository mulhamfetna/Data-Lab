# Copy to .streamlit/secrets.toml (git-ignored) for local use, or paste into
# Streamlit Community Cloud → App → Settings → Secrets for cloud deploys.
#
# Set ONE free provider to unlock the live GenAI paths. With none set, the GenAI
# demos run a clearly-labeled offline simulation — the app still works fully.

# Groq (free, fast) — https://console.groq.com/keys
# GROQ_API_KEY = "gsk_..."

# OpenRouter (free tier) — https://openrouter.ai/keys
# OPENROUTER_API_KEY = "sk-or-..."

# Hugging Face Inference Providers — https://huggingface.co/settings/tokens
# (fine-grained token with "Make calls to Inference Providers")
# Free accounts get a small monthly quota; PRO adds credits. Not unlimited.
# HF_TOKEN = "hf_..."

# Local Ollama (self-host only; not reachable from cloud)
# OLLAMA_HOST = "http://localhost:11434"

# Optional overrides
# LLM_PROVIDER = "groq"       # force a provider (groq | openrouter | hugging | ollama)
# LLM_MODEL = "llama-3.1-8b-instant"
#
# Default models per provider:
#   Groq        -> llama-3.1-8b-instant
#   OpenRouter  -> meta-llama/llama-3.2-3b-instruct:free
#   HuggingFace -> openai/gpt-oss-20b:cheapest   (open weights, cost-routed)
#   Ollama      -> llama3.2:1b                    (fully free, runs locally)
# On a Hugging Face Space, Hugging Face inference is preferred automatically.
